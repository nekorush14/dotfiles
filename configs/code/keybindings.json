[
  {
    "key": "shift+alt+=",
    "command": "editor.action.fontZoomIn"
  },
  {
    "key": "shift+alt+-",
    "command": "editor.action.fontZoomOut"
  },
  {
    "key": "ctrl+shift+alt+=",
    "command": "workbench.action.terminal.fontZoomIn"
  },
  {
    "key": "ctrl+shift+alt+-",
    "command": "workbench.action.terminal.fontZoomOut"
  }
]
